---
import BaseLayout from '../layouts/BaseLayout.astro';
import CurrentSongHero from '../components/CurrentSongHero.astro';
import SongCard from '../components/SongCard.astro';
import SongRow from '../components/SongRow.astro';
import IssueBar from '../components/IssueBar.astro';
import { getCollection } from 'astro:content';
import { issueNo, songCover, songSlug, sortByDateDesc } from '../utils/song';

const allSongs = await getCollection('songs');
const sorted = sortByDateDesc(allSongs);

const current = sorted[0];
const currentIssue = issueNo(current, allSongs);
const recent = sorted.slice(1, 5);
const totalCount = allSongs.length;
---

<BaseLayout title="Home">
  <IssueBar
    left={`Issue No. ${currentIssue}`}
    right={`${current.data.month} ${current.data.year}`}
  />

  <CurrentSongHero
    title={current.data.title}
    artist={current.data.artist}
    month={current.data.month}
    year={current.data.year}
    picker={current.data.picker}
    slug={songSlug(current)}
    issueNo={currentIssue}
    songKey={current.data.key}
    coverImage={songCover(current)}
    youtubeUrl={current.data.youtubeUrl}
    chordsUrl={current.data.chordsUrl}
  />

  <section class="border-b border-ink px-5 py-12 md:px-16 md:pt-16 md:pb-12">
    <div class="flex justify-between items-baseline mb-10">
      <h2 class="font-display font-black tracking-[-0.02em] text-[28px] md:text-[38px] m-0">From the archive</h2>
      <a href="/archive" class="font-sans uppercase text-muted hover:text-accent text-[11px] tracking-[0.18em] transition-colors">
        Recent · View all {totalCount} →
      </a>
    </div>

    <!-- Mobile: row list -->
    <div class="md:hidden">
      {recent.map((song, i) => (
        <SongRow
          title={song.data.title}
          artist={song.data.artist}
          month={song.data.month}
          year={song.data.year}
          picker={song.data.picker}
          slug={songSlug(song)}
          coverImage={songCover(song)}
          paletteIndex={i}
        />
      ))}
    </div>

    <!-- Desktop: card grid -->
    <div class="hidden md:grid grid-cols-4 gap-8">
      {recent.map((song, i) => (
        <SongCard
          title={song.data.title}
          artist={song.data.artist}
          month={song.data.month}
          year={song.data.year}
          picker={song.data.picker}
          slug={songSlug(song)}
          issueNo={issueNo(song, allSongs)}
          coverImage={songCover(song)}
          paletteIndex={i}
        />
      ))}
    </div>
  </section>

</BaseLayout>
