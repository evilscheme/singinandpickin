---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IssueBar from '../../components/IssueBar.astro';
import ArtworkTile from '../../components/ArtworkTile.astro';
import MetaRow from '../../components/MetaRow.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import PlayAlongChordChart from '../../components/PlayAlongChordChart.astro';
import ExtrasSection from '../../components/ExtrasSection.astro';
import { getCollection } from 'astro:content';
import { issueNo, songCover, songSlug, sortByDateDesc } from '../../utils/song';

export async function getStaticPaths() {
  const songs = await getCollection('songs');
  return songs.map((song) => ({
    params: { slug: `${song.data.year}/${song.id.split('/').pop()}` },
    props: { song },
  }));
}

interface Props {
  song: Awaited<ReturnType<typeof getCollection<'songs'>>>[number];
}

const { song } = Astro.props;

const allSongs = await getCollection('songs');
const sorted = sortByDateDesc(allSongs);
const currentIndex = sorted.findIndex((s) => s.id === song.id);
const prevSong = sorted[currentIndex + 1]; // older
const nextSong = sorted[currentIndex - 1]; // newer

const currentIssue = issueNo(song, allSongs);
const totalCount = allSongs.length;
// Same direction as issueNo: oldest = 1, newest = totalCount.
const positionFromOldest = totalCount - currentIndex;

const cells = [
  { label: 'Month', value: `${song.data.month} ${song.data.year}` },
  ...(song.data.key ? [{ label: 'Key', value: song.data.key }] : []),
  { label: 'Picked by', value: song.data.picker },
];

const byline = song.data.byline ?? song.data.artist;
const pickerInitial = song.data.picker.trim().charAt(0).toUpperCase();
---

<BaseLayout title={`${song.data.title} by ${song.data.artist}`}>
  <IssueBar
    left="← Archive"
    leftAccent
    leftHref="/archive"
    center={`No. ${currentIssue} · ${song.data.month} ${song.data.year}`}
    right={`${positionFromOldest} of ${totalCount}`}
  />

  <!-- Hero -->
  <section class="border-b border-ink px-5 py-12 md:px-16 md:pt-16 md:pb-12">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-[420px_1fr] md:gap-16 md:items-start">
      <div>
        <ArtworkTile coverImage={songCover(song)} alt={`${song.data.title} by ${song.data.artist}`} aspect="1" showLabel />
      </div>
      <div>
        <div class="eyebrow mb-6">This Month's Song · No. {currentIssue}</div>
        <h1
          class="font-display font-black tracking-[-0.025em] text-balance m-0 mb-3.5"
          style="font-size: clamp(40px, 8vw, 76px); line-height: 0.98;"
        >{song.data.title}</h1>
        <div class="font-display italic text-muted text-[18px] md:text-[24px] mb-7">by {byline}</div>

        {song.data.dek && (
          <p class="font-serif text-ink-soft text-[17px] md:text-[18px] leading-[1.55] text-pretty max-w-[56ch] mb-8">
            {song.data.dek}
          </p>
        )}

        <div class="mb-7">
          <MetaRow cells={cells} />
        </div>

        <div class="flex flex-col gap-3 md:flex-row md:flex-wrap">
          {song.data.youtubeUrl && (
            <a href="#listen" class="btn-primary">▶ Play recording</a>
          )}
          {song.data.youtubeUrl && (
            <a href={song.data.youtubeUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Listen on YouTube</a>
          )}
          {song.data.spotifyUrl && (
            <a href={song.data.spotifyUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Spotify</a>
          )}
          {song.data.chordsUrl && (
            <a href={song.data.chordsUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Chords</a>
          )}
          {song.data.printableUrl && (
            <a href={song.data.printableUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Printable</a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Listen -->
  {song.data.youtubeUrl && (
    <section id="listen" class="border-b border-ink px-5 py-12 md:px-16 md:pt-16 md:pb-12 scroll-mt-8">
      <div class="flex justify-between items-baseline mb-7">
        <h2 class="font-display font-black tracking-[-0.02em] text-[26px] md:text-[32px] m-0">Listen</h2>
        <span class="font-sans uppercase text-muted text-[11px] tracking-[0.18em]">{song.data.artist}</span>
      </div>
      <YouTubeEmbed url={song.data.youtubeUrl} title={song.data.title} />
    </section>
  )}

  <!-- Extras -->
  {song.data.extras && (
    <section class="border-b border-ink px-5 py-12 md:px-16 md:pt-16 md:pb-12">
      <ExtrasSection extras={song.data.extras} />
    </section>
  )}

  <!-- Chords & lyrics -->
  {song.body && song.body.trim() && (
    <section class="border-b border-ink px-5 py-12 md:px-16 md:pt-16 md:pb-12">
      <PlayAlongChordChart content={song.body} title={song.data.title} songKey={song.data.key} />
    </section>
  )}

  <!-- Picker's notes -->
  {song.data.pickerNote && (
    <section class="border-b border-ink px-5 py-12 md:px-16 md:py-12">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-[1fr_2fr] md:gap-16">
        <div>
          <div class="eyebrow mb-3.5">Picker's notes</div>
          <div class="font-display italic text-muted text-[18px] md:text-[20px] leading-[1.3]">
            Why this song,<br />why this month.
          </div>
        </div>
        <div>
          <div class="font-display text-ink text-[17px] md:text-[19px] leading-[1.5] text-pretty">
            {song.data.pickerNote}
          </div>
          <div class="mt-6 pt-4 border-t border-ink flex items-center gap-3.5">
            <div class="w-12 h-12 rounded-full bg-accent text-paper font-display font-bold text-[22px] flex items-center justify-center">
              {pickerInitial}
            </div>
            <div>
              <div class="font-sans uppercase text-muted text-[9px] tracking-[0.28em] mb-0.5">Picked by</div>
              <div class="font-display italic text-[18px]">{song.data.picker}, {song.data.month} {song.data.year}</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Prev / Next -->
  <nav class="border-b border-ink px-5 py-8 md:px-16 md:py-9">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-0">
      {prevSong ? (
        <a href={`/songs/${songSlug(prevSong)}`} class="block group">
          <div class="font-sans uppercase text-muted text-[10px] tracking-[0.22em] mb-2">
            ← Previous · No. {issueNo(prevSong, allSongs)}
          </div>
          <div class="font-display font-bold text-[22px] md:text-[28px] tracking-[-0.01em] leading-[1.05] mb-1 group-hover:text-accent transition-colors">
            {prevSong.data.title}
          </div>
          <div class="font-display italic text-muted text-[14px] md:text-[15px]">
            {prevSong.data.artist} · {prevSong.data.month} {prevSong.data.year}
          </div>
        </a>
      ) : (
        <div></div>
      )}
      {nextSong ? (
        <a
          href={`/songs/${songSlug(nextSong)}`}
          class="block group md:text-right md:border-l md:border-ink md:pl-8 md:ml-8"
        >
          <div class="font-sans uppercase text-muted text-[10px] tracking-[0.22em] mb-2">
            Next · No. {issueNo(nextSong, allSongs)} →
          </div>
          <div class="font-display font-bold text-[22px] md:text-[28px] tracking-[-0.01em] leading-[1.05] mb-1 group-hover:text-accent transition-colors">
            {nextSong.data.title}
          </div>
          <div class="font-display italic text-muted text-[14px] md:text-[15px]">
            {nextSong.data.artist} · {nextSong.data.month} {nextSong.data.year}
          </div>
        </a>
      ) : (
        <div></div>
      )}
    </div>
  </nav>
</BaseLayout>
