---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SongCard from '../../components/SongCard.astro';
import SongRow from '../../components/SongRow.astro';
import IssueBar from '../../components/IssueBar.astro';
import { getCollection } from 'astro:content';
import { issueNo, songCover, songSlug, sortByDateDesc } from '../../utils/song';

export async function getStaticPaths() {
  const allSongs = await getCollection('songs');
  const years = [...new Set(allSongs.map((s) => s.data.year))];

  return years.map((year) => ({
    params: { year: String(year) },
    props: {
      year,
      songs: sortByDateDesc(allSongs.filter((s) => s.data.year === year)),
    },
  }));
}

interface Props {
  year: number;
  songs: Awaited<ReturnType<typeof getCollection<'songs'>>>;
}

const { year, songs } = Astro.props;

const allSongs = await getCollection('songs');
const allYears = [...new Set(allSongs.map((s) => s.data.year))].sort((a, b) => b - a);
---

<BaseLayout title={`${year} · Archive`}>
  <IssueBar
    left="← Archive"
    leftAccent
    leftHref="/archive"
    right={`${songs.length} songs in ${year}`}
  />

  <section class="px-5 py-12 md:px-16 md:pt-16 md:pb-12">
    <h1 class="font-display font-black tracking-[-0.025em] text-[44px] md:text-[60px] leading-[1] m-0 mb-10">{year}</h1>

    <nav class="flex flex-wrap gap-2 mb-12 pb-6 border-b border-ink" aria-label="Years">
      {allYears.map((y) => (
        <a
          href={`/archive/${y}`}
          aria-current={y === year ? 'page' : undefined}
          class:list={[
            'font-sans uppercase text-[11px] tracking-[0.18em] px-3 py-2 border border-ink transition-colors',
            y === year ? 'bg-ink text-paper' : 'hover:bg-ink hover:text-paper',
          ]}
        >
          {y}
        </a>
      ))}
    </nav>

    <div class="md:hidden">
      {songs.map((song, i) => (
        <SongRow
          title={song.data.title}
          artist={song.data.artist}
          month={song.data.month}
          year={song.data.year}
          picker={song.data.picker}
          slug={songSlug(song)}
          coverImage={songCover(song)}
          paletteIndex={i}
        />
      ))}
    </div>

    <ul class="hidden md:grid md:grid-cols-3 lg:grid-cols-4 gap-8 list-none p-0 m-0">
      {songs.map((song, i) => (
        <li>
          <SongCard
            title={song.data.title}
            artist={song.data.artist}
            month={song.data.month}
            year={song.data.year}
            picker={song.data.picker}
            slug={songSlug(song)}
            issueNo={issueNo(song, allSongs)}
            coverImage={songCover(song)}
            paletteIndex={i}
          />
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
