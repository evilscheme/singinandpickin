---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SongCard from '../../components/SongCard.astro';
import SongRow from '../../components/SongRow.astro';
import IssueBar from '../../components/IssueBar.astro';
import { getCollection } from 'astro:content';
import { issueNo, songCover, songSlug, sortByDateDesc } from '../../utils/song';

const allSongs = await getCollection('songs');
const sorted = sortByDateDesc(allSongs);

const songsByYear: Record<number, typeof allSongs> = {};
for (const song of sorted) {
  (songsByYear[song.data.year] ||= []).push(song);
}
const years = Object.keys(songsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="Archive">
  <IssueBar
    left={`Archive · ${allSongs.length} songs`}
    right=""
  />

  <section class="px-5 py-12 md:px-16 md:pt-16 md:pb-12">
    <div class="mb-12 flex flex-wrap items-baseline justify-between gap-4">
      <h1 class="font-display font-black tracking-[-0.025em] text-[44px] md:text-[60px] leading-[1] m-0">Archive</h1>
      <p class="font-serif text-muted text-[17px] max-w-[40ch] text-pretty">
        All the songs we've ever sung
      </p>
    </div>

    <nav class="flex flex-wrap gap-2 mb-12 pb-6 border-b border-ink" aria-label="Years">
      {years.map((year) => (
        <a
          href={`#year-${year}`}
          class="group font-sans uppercase text-[11px] tracking-[0.18em] px-3 py-2 border border-ink hover:bg-ink hover:text-paper transition-colors"
        >
          {year}
          <span class="ml-1.5 normal-case tracking-normal text-muted group-hover:text-paper/70">({songsByYear[year].length})</span>
        </a>
      ))}
    </nav>

    {years.map((year) => (
      <section id={`year-${year}`} class="mb-16 scroll-mt-8">
        <div class="flex items-baseline justify-between mb-8 pb-4 border-b border-ink">
          <h2 class="font-display font-black tracking-[-0.02em] text-[32px] md:text-[38px] m-0">{year}</h2>
          <span class="font-sans uppercase text-muted text-[11px] tracking-[0.18em]">
            {songsByYear[year].length} {songsByYear[year].length === 1 ? 'song' : 'songs'}
          </span>
        </div>

        <div class="md:hidden">
          {songsByYear[year].map((song, i) => (
            <SongRow
              title={song.data.title}
              artist={song.data.artist}
              month={song.data.month}
              year={song.data.year}
              picker={song.data.picker}
              slug={songSlug(song)}
              coverImage={songCover(song)}
              paletteIndex={i}
            />
          ))}
        </div>

        <ul class="hidden md:grid md:grid-cols-3 lg:grid-cols-4 gap-8 list-none p-0 m-0">
          {songsByYear[year].map((song, i) => (
            <li>
              <SongCard
                title={song.data.title}
                artist={song.data.artist}
                month={song.data.month}
                year={song.data.year}
                picker={song.data.picker}
                slug={songSlug(song)}
                issueNo={issueNo(song, allSongs)}
                coverImage={songCover(song)}
                paletteIndex={i}
              />
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>
