---
import ArtworkTile from './ArtworkTile.astro';
import { archiveCardPalette } from '../utils/song';

interface Props {
  title: string;
  artist: string;
  month: string;
  year: number;
  picker: string;
  slug: string;
  issueNo: string;
  coverImage?: string;
  /** Index used to pick a fallback solid color when no coverImage is present. */
  paletteIndex?: number;
}

const { title, artist, month, year, picker, slug, issueNo, coverImage, paletteIndex = 0 } = Astro.props;
const fallback = archiveCardPalette[paletteIndex % archiveCardPalette.length];
---

<a href={`/songs/${slug}`} class="block group">
  <div class="mb-4">
    <ArtworkTile
      coverImage={coverImage}
      alt={`${title} by ${artist}`}
      aspect="1"
      solidColor={coverImage ? undefined : fallback}
    />
  </div>
  <div class="font-display italic text-accent text-[13px] mb-1.5">No. {issueNo}</div>
  <h3 class="font-display font-bold text-[22px] leading-[1.1] tracking-[-0.01em] text-balance text-ink m-0 group-hover:text-accent transition-colors">{title}</h3>
  <div class="font-display italic text-[14px] text-muted mt-1 mb-3">{artist}</div>
  <div class="flex justify-between pt-2.5 border-t border-ink font-sans uppercase text-muted text-[10px] tracking-[0.16em]">
    <span>{month} {year}</span>
    <span>Picked by {picker}</span>
  </div>
</a>
