---
import ArtworkTile from './ArtworkTile.astro';
import MetaRow from './MetaRow.astro';
import { heroTitleSize } from '../utils/song';
import { getYouTubeThumbnail } from '../utils/youtube';

interface Props {
  title: string;
  artist: string;
  month: string;
  year: number;
  picker: string;
  slug: string;
  issueNo: string;
  songKey?: string;
  coverImage?: string;
  youtubeUrl?: string;
  chordsUrl?: string;
}

const {
  title,
  artist,
  month,
  year,
  picker,
  slug,
  issueNo,
  songKey,
  coverImage,
  youtubeUrl,
  chordsUrl,
} = Astro.props;

const displayImage = coverImage || (youtubeUrl ? getYouTubeThumbnail(youtubeUrl) : null) || undefined;

const { fontSize, lineHeight } = heroTitleSize(title);

// Mobile cap: clamp(28px, 8vw, 40px) regardless of length.
const desktopHeadline = `font-size: ${fontSize}px; line-height: ${lineHeight};`;
const mobileHeadline = `font-size: clamp(28px, 8vw, 40px); line-height: 0.95;`;

const cells = [
  { label: 'Month', value: `${month} ${year}` },
  ...(songKey ? [{ label: 'Key', value: songKey }] : []),
  { label: 'Picked by', value: picker },
];
---

<section class="border-b border-ink px-5 py-12 md:px-[88px] md:pt-[88px] md:pb-[80px]">
  <div class="grid grid-cols-1 gap-10 md:grid-cols-[1.05fr_1fr] md:gap-24 md:items-start">
    <div>
      <div class="eyebrow mb-7">This Month's Song · No. {issueNo}</div>

      <h1
        class="font-display font-black text-balance tracking-[-0.025em] m-0 mb-[18px] hero-headline"
        data-desktop-style={desktopHeadline}
        data-mobile-style={mobileHeadline}
      ><a href={`/songs/${slug}`} class="text-ink hover:text-accent transition-colors">{title}</a></h1>

      <div class="font-display italic text-muted text-[18px] md:text-[22px] mb-9">by {artist}</div>

      <a href={`/songs/${slug}`} class="md:hidden block mb-6">
        <ArtworkTile coverImage={displayImage} alt={`${title} by ${artist}`} aspect="1" showLabel />
      </a>

      <div class="mb-8">
        <MetaRow cells={cells} />
      </div>

      <div class="flex flex-col gap-3 md:flex-row md:flex-wrap md:gap-3">
        <a href={`/songs/${slug}`} class="btn-primary">Open Song Page →</a>
        {youtubeUrl && (
          <a href={youtubeUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Listen on YouTube</a>
        )}
        {chordsUrl && (
          <a href={chordsUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">Chords</a>
        )}
      </div>
    </div>

    <a href={`/songs/${slug}`} class="hidden md:block">
      <ArtworkTile coverImage={displayImage} alt={`${title} by ${artist}`} aspect="1 / 1.18" showLabel />
    </a>
  </div>
</section>

<style>
  .hero-headline {
    font-size: clamp(28px, 8vw, 40px);
    line-height: 0.95;
  }
  @media (min-width: 768px) {
    .hero-headline {
      /* Desktop sizes are injected via inline style by the script below. */
    }
  }
</style>

<script>
  // Apply the auto-sized desktop styles only above the md breakpoint, falling back to clamp on mobile.
  const apply = () => {
    const isDesktop = window.matchMedia('(min-width: 768px)').matches;
    document.querySelectorAll<HTMLElement>('.hero-headline').forEach((el) => {
      el.style.cssText = isDesktop
        ? (el.dataset.desktopStyle ?? '')
        : (el.dataset.mobileStyle ?? '');
    });
  };
  apply();
  window.addEventListener('resize', apply);
</script>
