---
/**
 * Apple Music app glyph: white beamed double-note on the red/pink gradient
 * squircle. Approximation of the real app icon.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 18, class: className } = Astro.props;
// Gradient id must be unique per instance on a page; our two usages differ in size.
const gradId = `apple-music-grad-${size}`;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  class={className}
  role="img"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={gradId} x1="12" y1="2" x2="12" y2="22" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#FC6A73" />
      <stop offset="1" stop-color="#FA2336" />
    </linearGradient>
  </defs>
  <rect x="1.5" y="1.5" width="21" height="21" rx="5.4" fill={`url(#${gradId})`} />
  <g fill="#fff">
    <!-- stems -->
    <rect x="9.5" y="7" width="1.1" height="9" rx="0.55" />
    <rect x="15.6" y="5.5" width="1.1" height="9" rx="0.55" />
    <!-- beam joining the two stems -->
    <path d="M9.5 7 L16.7 5.5 L16.7 7.1 L9.5 8.6 Z" />
    <!-- note heads -->
    <ellipse cx="8.5" cy="16" rx="2.1" ry="1.6" transform="rotate(-18 8.5 16)" />
    <ellipse cx="14.6" cy="14.5" rx="2.1" ry="1.6" transform="rotate(-18 14.6 14.5)" />
  </g>
</svg>
